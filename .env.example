# 프로젝트 루트 .env — docker compose가 자동으로 읽는다.
# `cp .env.example .env` 후 OPENAI_API_KEY만 채우면 `docker compose up -d` 가능.

OPENAI_API_KEY=

# 아래는 모두 기본값 있음. 바꾸고 싶을 때만.
POSTGRES_USER=team20
POSTGRES_PASSWORD=team20pw
POSTGRES_DB=team20
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000

EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o
SIMILARITY_THRESHOLD=0.40
LLM_THRESHOLD=7

# Upstage solar-pro2 (자연어 → 함수 호출 플랜) — https://console.upstage.ai/api-keys
# 빈 값이면 ai_agent가 fallback(룰 기반) 파서로 동작.
SECRET_KEY=
UPSTAGE_MODEL=solar-pro2
UPSTAGE_CHAT_COMPLETIONS_URL=https://api.upstage.ai/v1/solar/chat/completions
UPSTAGE_TIMEOUT_SECONDS=20

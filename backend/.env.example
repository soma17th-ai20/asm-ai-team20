OPENAI_API_KEY=
SIMILARITY_THRESHOLD=0.40
LLM_THRESHOLD=7
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o

REDIS_HOST=localhost
REDIS_PORT=6379

# docker-compose 기본값. POSTGRES_* 는 docker-compose가 읽고
# DATABASE_URL은 백엔드 애플리케이션이 읽는다.
POSTGRES_USER=team20
POSTGRES_PASSWORD=team20pw
POSTGRES_DB=team20
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://team20:team20pw@localhost:5432/team20

# Upstage solar-pro2 (ai_agent 모듈) — https://console.upstage.ai/api-keys
# 빈 값이면 룰 기반 fallback 파서 사용.
SECRET_KEY=
UPSTAGE_MODEL=solar-pro2
UPSTAGE_CHAT_COMPLETIONS_URL=https://api.upstage.ai/v1/solar/chat/completions
UPSTAGE_TIMEOUT_SECONDS=20

# 스케줄러 (이주호) — APScheduler가 POST /api/crawl 주기 호출
CRAWLER_API_URL=http://localhost:8000
CRAWL_INTERVAL_MINUTES=30

# 알림 이메일 발송 (이주호) — Gmail은 앱 비밀번호
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DEV_RECIPIENT_EMAIL=

# 유저당 일일 알림 한도 (KST 자정 리셋)
DAILY_LIMIT_PER_USER=5

# Slack 슬래시 커맨드 서명 검증 (Slack 앱의 Basic Information → Signing Secret)
# 비어있으면 검증 스킵 (개발용 — 운영에서는 반드시 설정).
SLACK_SIGNING_SECRET=
